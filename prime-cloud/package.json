{
  "name": "prime-cloud",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "@prisma/client", "@prisma/engines", "msgpackr-extract", "prisma", "sharp"]
  },
  "scripts": {
    "preinstall": "node -e 'if(!/pnpm/.test(process.env.npm_execpath||\"\"))throw new Error(\"Use pnpm (npm install -g pnpm@10) to install dependencies\")'",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@prime-cloud/api",
    "dev:dashboard": "turbo dev --filter=@prime-cloud/dashboard",
    "dev:pos": "turbo dev --filter=@prime-cloud/pos",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "@changesets/cli": "^2.27.0"
  }
}
