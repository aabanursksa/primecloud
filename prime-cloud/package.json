{
  "name": "prime-cloud",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "turbo:build": "turbo build",
    "turbo:lint": "turbo lint",
    "turbo:typecheck": "turbo typecheck",
    "build": "echo 'Prime Cloud ready. Use deploy/ for production.'; exit 0",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@prime-cloud/api",
    "dev:dashboard": "turbo dev --filter=@prime-cloud/dashboard",
    "dev:pos": "turbo dev --filter=@prime-cloud/pos",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css}\"",
    "start": "node deploy/server.js"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "@changesets/cli": "^2.27.0"
  }
}
