{
  "name": "prime-cloud",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.8.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "build:api": "npm run build -w apps/api",
    "build:dashboard": "npm run build -w apps/dashboard",
    "build:pos": "npm run build -w apps/pos",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@prime-cloud/api",
    "dev:dashboard": "turbo dev --filter=@prime-cloud/dashboard",
    "dev:pos": "turbo dev --filter=@prime-cloud/pos",
    "format": "prettier --write .",
    "start": "node deploy/server.js"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "@changesets/cli": "^2.27.0",
    "@types/jest": "^29.5.0"
  }
}
