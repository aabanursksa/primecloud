{
  "name": "prime-cloud",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "turbo:build": "turbo build",
    "turbo:lint": "turbo lint",
    "turbo:typecheck": "turbo typecheck",
    "build": "echo '[Hostinger] Production build handled by CI/CD. Use \"pnpm turbo:build\" for local build.' && npm install --prefix deploy --legacy-peer-deps 2>/dev/null; exit 0",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@prime-cloud/api",
    "dev:dashboard": "turbo dev --filter=@prime-cloud/dashboard",
    "dev:pos": "turbo dev --filter=@prime-cloud/pos",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css}\"",
    "start": "node deploy/server.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "@changesets/cli": "^2.27.0"
  }
}
